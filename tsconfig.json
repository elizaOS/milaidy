{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ScriptHost"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2023",
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@elizaos/app-hyperscape/routes": [
        "../plugins/app-hyperscape/src/routes.ts"
      ],
      "@elizaos/autonomous/config/types.milady": [
        "node_modules/@elizaos/autonomous/src/config/types.milady.ts"
      ],
      "@elizaos/autonomous/runtime/milady-plugin": [
        "node_modules/@elizaos/autonomous/src/runtime/milady-plugin.ts"
      ],
      "@elizaos/autonomous/runtime/cloud-onboarding": [
        "node_modules/@elizaos/autonomous/src/runtime/cloud-onboarding.ts"
      ],
      "@elizaos/plugin-streaming-base": [
        "../plugins/plugin-streaming-base/src/index.ts"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "packages",
    "plugins",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/test-helpers.ts",
    "src/services/training-service.ts",
    "src/plugins/retake/**"
  ]
}
