# Milady runtime environment example
# Copy to .env or ~/.eliza/.env as needed.

# ----------------------------------------------------------------------------
# Model provider API keys (at least one required)
# ----------------------------------------------------------------------------

# Anthropic (recommended — Claude models)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, o1, Codex)
OPENAI_API_KEY=

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# Gemini aliases (optional). Runtime maps these to GOOGLE_GENERATIVE_AI_API_KEY
# if canonical key is unset.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Groq (fast inference)
GROQ_API_KEY=

# OpenRouter (100+ models, one API)
OPENROUTER_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ----------------------------------------------------------------------------
# Runtime configuration
# ----------------------------------------------------------------------------

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Server ports (defaults shown)
# MILADY_GATEWAY_PORT=18789
# MILADY_PORT=2138
# MILADY_API_PORT=31337

# Bind address (default: 127.0.0.1 — set to 0.0.0.0 for network access)
# MILADY_API_BIND=127.0.0.1

# API auth token (REQUIRED when MILADY_API_BIND is not loopback)
# MILADY_API_TOKEN=

# CORS origins (comma-separated, only needed for remote/cloud deployments)
# MILADY_ALLOWED_ORIGINS=https://app.milady.ai

# Config file override (default: ~/.eliza/eliza.json)
# ELIZA_CONFIG_PATH=
# ELIZA_STATE_DIR=

# ----------------------------------------------------------------------------
# Development flags
# ----------------------------------------------------------------------------

# Skip local Eliza workspace linking (use npm-published @elizaos/* packages)
# ELIZA_SKIP_LOCAL_ELIZA=1

# Force rebuild of Eliza packages on every build
# ELIZA_FORCE_BUILD=1

# Dev server log level override
# ELIZA_DEV_LOG_LEVEL=debug

# Skip native dependency installation (canvas, tensorflow, whisper)
# ELIZA_SKIP_NATIVE=1

# ----------------------------------------------------------------------------
# GitHub / coding-agent credentials
# ----------------------------------------------------------------------------

# GitHub PAT for repo access, PR creation, and gh operations in agents.
GITHUB_TOKEN=

# GitHub OAuth device-flow client id (fallback when GITHUB_TOKEN is not set).
GITHUB_OAUTH_CLIENT_ID=

# Optional OAuth secret (only needed for specific OAuth flows/environments).
GITHUB_OAUTH_CLIENT_SECRET=

# Optional comma-separated allow-list of additional credential env keys that
# coding agents may receive (example: "LINEAR_API_KEY,SLACK_BOT_TOKEN").
CUSTOM_CREDENTIAL_KEYS=

# ----------------------------------------------------------------------------
# Swarm/orchestrator behavior controls
# ----------------------------------------------------------------------------

# Agent selection strategy when starting coding tasks:
# - fixed  (default): always use PARALLAX_DEFAULT_AGENT_TYPE
# - ranked          : auto-pick best installed agent via metrics
PARALLAX_AGENT_SELECTION_STRATEGY=fixed

# Used when strategy=fixed. Allowed values: claude | gemini | codex | aider
PARALLAX_DEFAULT_AGENT_TYPE=claude

# Default permission preset for newly spawned coding agents.
# Allowed values: readonly | standard | permissive | autonomous
# Default: permissive
PARALLAX_DEFAULT_APPROVAL_PRESET=permissive

# Aider backend provider (used when default/selected agent is aider).
# Allowed values in Milady settings UI: anthropic | openai | google
PARALLAX_AIDER_PROVIDER=anthropic

# ----------------------------------------------------------------------------
# Optional model overrides (per coding agent family)
# ----------------------------------------------------------------------------
# Leave empty to use adapter defaults. Set to exact model IDs when pinning.

PARALLAX_CLAUDE_MODEL_POWERFUL=
PARALLAX_CLAUDE_MODEL_FAST=

PARALLAX_GEMINI_MODEL_POWERFUL=
PARALLAX_GEMINI_MODEL_FAST=

PARALLAX_CODEX_MODEL_POWERFUL=
PARALLAX_CODEX_MODEL_FAST=

PARALLAX_AIDER_MODEL_POWERFUL=
PARALLAX_AIDER_MODEL_FAST=

# ----------------------------------------------------------------------------
# Benchmark / replay capture helpers (internal testing)
# ----------------------------------------------------------------------------

# Enable debug capture artifacts for replay/benchmark tooling.
# Values: 1 (enabled), unset/0 (disabled)
PARALLAX_DEBUG_CAPTURE=

# Auto-run benchmark preflight setup before coding sessions.
# Values: 1 (enabled), unset/0 (disabled)
PARALLAX_BENCHMARK_PREFLIGHT_AUTO=

# Preflight mode:
# - cold (default): removes venv then recreates and reinstalls deps
# - warm          : reuses existing venv when valid
PARALLAX_BENCHMARK_PREFLIGHT_MODE=cold

# Relative venv directory under target workdir for benchmark preflight.
# Must stay inside the workdir. Default: .benchmark-venv
PARALLAX_BENCHMARK_PREFLIGHT_VENV=.benchmark-venv
