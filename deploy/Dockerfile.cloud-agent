# ─────────────────────────────────────────────────────────────────────────────
# elizaOS Cloud Agent — Slim Bridge-Only Image
#
# Minimal container that runs ONLY the cloud-agent bridge daemon.
# No milady server, no frontend, no build tools.
# Uses the pre-built packages/cloud-agent/dist/ output (pure JS, zero npm deps).
#
# Build (from repo root):
#   docker build -f deploy/Dockerfile.cloud-agent -t milady/agent:cloud-slim .
#
# Run:
#   docker run -p 2138:2138 -p 31337:31337 -p 18790:18790 \
#     -e ELIZAOS_CLOUD_API_KEY=eliza_xxx \
#     milady/agent:cloud-slim
# ─────────────────────────────────────────────────────────────────────────────

FROM node:22-bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the pre-built cloud-agent package (pure JS, only needs node builtins)
COPY packages/cloud-agent/dist/ ./dist/
COPY packages/cloud-agent/package.json ./
COPY packages/cloud-agent/bin/ ./bin/

# No npm install needed — cloud-agent dist uses only node:http, node:crypto
# Peer deps (@elizaos/core etc.) are optional and not required for standalone bridge mode

ENV NODE_ENV=production
ENV PORT=2138
ENV BRIDGE_PORT=31337
ENV BRIDGE_COMPAT_PORT=18790

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=5 \
  CMD curl -f http://localhost:${PORT}/health || exit 1

EXPOSE 2138 31337 18790

# Security: run as non-root
RUN useradd -m agent
USER agent

CMD ["node", "bin/cloud-agent.mjs", "start"]
