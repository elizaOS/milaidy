{
  "name": "@milady/electrobun",
  "version": "2.0.0-alpha.82",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run build:preload && electrobun dev",
    "dev": "bun run build:preload && electrobun dev --watch",
    "build:canary": "bun run build:preload && electrobun build --env=canary",
    "build:stable": "bun run build:preload && electrobun build --env=stable",
    "build:preload": "bun build src/bridge/electrobun-preload.ts --target browser --format iife --outfile src/preload.js --minify",
    "build:native-effects": "bash scripts/build-macos-effects.sh",
    "build:whisper": "bash scripts/build-whisper.sh",
    "build:whisper:universal": "bash scripts/build-whisper-universal.sh",
    "test": "bunx vitest run --config vitest.config.ts",
    "test:coverage": "bunx vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "bunx @biomejs/biome check src"
  },
  "dependencies": {
    "bonjour-service": "1.3.0",
    "electrobun": "^1.15.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "^1.3.8",
    "vitest": "^4.0.18",
    "@biomejs/biome": "^2.3.11"
  }
}
