{
  "name": "Milady",
  "version": "2.0.0-alpha.27",
  "description": "Cute agents for the acceleration",
  "homepage": "https://github.com/miladybsc/milady",
  "author": {
    "name": "Milady AI",
    "email": "hi@milady.ai"
