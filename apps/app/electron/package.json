  "main": "tsc-out/src/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.rmSync('build',{recursive:true,force:true});fs.cpSync('tsc-out','build',{recursive:true})\" && electron-rebuild",
    "build:whisper": "bash ./scripts/build-whisper-universal.sh",
    "electron:start-live": "node ./live-runner.js",
    "electron:start": "bun run build && node ./scripts/run-electron-main.cjs --inspect=5858 ./",
    "electron:pack": "bun run build && bun run build:whisper && electron-builder build --dir -c ./electron-builder.config.json",
    "electron:make": "bun run build && bun run build:whisper && electron-builder build -c ./electron-builder.config.json -p always",
    "electron:make:dmg:test": "bun run build && bun run build:whisper && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --mac dmg -c ./electron-builder.config.json -p never"
  },
  "dependencies": {
