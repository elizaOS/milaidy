{
  "npmRebuild": false,
  "appId": "com.miladyai.milady",
  "productName": "Milady",
  "directories": {
    "app": ".",
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "tsc-out/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*",
    "milady-dist/**/*",
    "*.tar.gz"
  ],
  "asarUnpack": [
    "milady-dist/**/*",
    "*.tar.gz",
    "node_modules/@tensorflow/tfjs-node/lib/**"
  ],
  "publish": {
    "provider": "github",
    "owner": "milady-ai",
    "repo": "milady"
  },
  "compression": "normal",
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Milady",
    "include": "resources/windows-long-paths.nsh"
  },
  "win": {
    "target": "nsis",
    "icon": "assets/appIcon.ico"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "assets/appIcon.png",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "entitlements.mac.plist",
    "entitlementsInherit": "entitlements.mac.plist",
    "notarize": true
  },
  "dmg": {
    "format": "UDZO",
    "background": "assets/dmg-background.png",
    "iconSize": 80,
    "window": {
      "width": 660,
      "height": 400
    },
    "contents": [
      {
        "x": 170,
        "y": 195,
        "type": "file"
      },
      {
        "x": 490,
        "y": 195,
        "type": "link",
        "path": "/Applications"
      }
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility",
    "icon": "assets/appIcon.png"
  }
}