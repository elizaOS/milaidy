{
  "name": "@miladyai/home-electrobun",
  "version": "2.0.0-alpha.87",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build:preload && PATH=\"$PWD/scripts/bin:$PATH\" bunx electrobun dev",
    "build": "bun run build:preload && PATH=\"$PWD/scripts/bin:$PATH\" bunx electrobun build",
    "typecheck": "tsc --noEmit",
    "build:preload": "bun build ../../app/electrobun/src/bridge/electrobun-preload.ts --target browser --format iife --outfile src/preload.js --minify"
  },
  "dependencies": {
    "bonjour-service": "1.3.0",
    "electrobun": "^1.16.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "^1.3.8"
  }
}
