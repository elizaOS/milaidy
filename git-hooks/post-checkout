#!/bin/sh
if ! command -v git-lfs >/dev/null 2>&1; then
  printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. Continuing checkout without Git LFS. Install git-lfs to fetch large assets (VRMs/animations)."
  exit 0
fi

git lfs post-checkout "$@"
